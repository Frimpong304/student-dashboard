<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.dashboard.controller.TimetableController"
      spacing="16" styleClass="content-area">

    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Examination Timetable"
               styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="examTypeFilter"
                  prefWidth="160"
                  promptText="All Exam Types"/>
    </HBox>

    <!-- Alert for upcoming exam -->
    <VBox fx:id="upcomingAlert"
          styleClass="welcome-banner" spacing="4"
          visible="false" managed="false">
        <padding>
            <Insets top="12" right="20" bottom="12" left="20"/>
        </padding>
        <Label fx:id="upcomingAlertLabel"
               text="" styleClass="welcome-title"
               style="-fx-font-size: 13px;"/>
        <Label fx:id="upcomingAlertSub"
               text="" styleClass="welcome-date"/>
    </VBox>

    <!-- Timetable Table -->
    <VBox styleClass="section-card" spacing="12"
          VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="20" right="20"
                    bottom="20" left="20"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="My Exam Schedule"
                   styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="examCountLabel"
                   text="0 exams"
                   styleClass="stats-text"/>
        </HBox>

        <TableView fx:id="timetableTable"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="ttTypeCol"
                             text="Type" prefWidth="100"/>
                <TableColumn fx:id="ttDateCol"
                             text="Date" prefWidth="110"/>
                <TableColumn fx:id="ttStartCol"
                             text="Start" prefWidth="80"/>
                <TableColumn fx:id="ttEndCol"
                             text="End" prefWidth="80"/>
                <TableColumn fx:id="ttCodeCol"
                             text="Course" prefWidth="80"/>
                <TableColumn fx:id="ttNameCol"
                             text="Course Name"
                             prefWidth="200"/>
                <TableColumn fx:id="ttVenueCol"
                             text="Venue" prefWidth="130"/>
                <TableColumn fx:id="ttCountdownCol"
                             text="Countdown" prefWidth="130"/>
            </columns>
            <placeholder>
                <Label text="No exams scheduled yet."/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>